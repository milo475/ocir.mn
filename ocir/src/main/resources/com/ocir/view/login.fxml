<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.ocir.controller.LoginController"
           stylesheets="@../css/style.css" styleClass="login-bg" prefWidth="800" prefHeight="600">
    <VBox alignment="CENTER" spacing="20" maxWidth="420" styleClass="login-card">
        <padding><Insets top="50" right="50" bottom="50" left="50"/></padding>

        <!-- Logo Section -->
        <VBox alignment="CENTER" spacing="5" styleClass="logo-section">
            <HBox alignment="CENTER" spacing="8">
                <Circle radius="8" styleClass="logo-dot"/>
                <Label text="Ocir" styleClass="logo-text"/>
                <Circle radius="8" styleClass="logo-dot"/>
            </HBox>
            <Label text="Холбогдох • Хуваалцах • Нээх" styleClass="logo-subtitle"/>
        </VBox>

        <Separator styleClass="login-separator"/>

        <Label text="Нэвтрэх" styleClass="form-title"/>
        <TextField fx:id="usernameField" promptText="Хэрэглэгчийн нэр" styleClass="form-input"/>
        <PasswordField fx:id="passwordField" promptText="Нууц үг" styleClass="form-input"/>
        <Label fx:id="errorLabel" styleClass="error-label"/>
        <Button text="Нэвтрэх" onAction="#handleLogin" styleClass="btn-primary" maxWidth="Infinity"/>
        <Hyperlink text="Бүртгэлгүй юу? Бүртгүүлэх" onAction="#goToRegister" styleClass="link"/>
    </VBox>
</StackPane>
